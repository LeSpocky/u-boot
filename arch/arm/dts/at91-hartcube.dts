/*
 * at91-hartcube.dts - Device Tree file for Thorsis Technologies HARTcube board
 *
 * © 2024 Thorsis Technologies GmbH
 */
/dts-v1/;
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pinctrl/at91.h>
#include <efinix.h>
#include "sam9x60.dtsi"

/ {
	model = "Thorsis Technologies HARTcube";
	compatible = "thorsis,hartcube", "microchip,sam9x60", "atmel,at91sam9";

	aliases {
		serial0 = &dbgu;
		gpio0 = &pioA;
		gpio1 = &pioB;
		gpio2 = &pioC;
		gpio3 = &pioD;
		spi0 = &soft_spi;
	};

	chosen {
		stdout-path = &dbgu;
	};

	memory {
		reg = <0x20000000 0x04000000>;
	};

	clocks {
		slow_xtal: slow_xtal {
			clock-frequency = <32768>;
		};

		main_xtal: main_xtal {
			clock-frequency = <24000000>;
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "okay";

		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_key_gpio_default>;

		reset {
			label = "reset";
			gpios = <&pioD 21 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};

	led-controller-0 {
		compatible = "gpio-leds";
		status = "okay";

		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_gpio_leds>;

		/*
		 * Four dual color (red/green) LEDs.
		 *
		 * NOTE	If you switch ON both colors of the same LED,
		 *	it will go off. We're just misusing the
		 *	gpio-leds driver here for simplicity.
		 */

		/*
		 * (this led could use pwm, but we use it as simple gpio-led in u-boot only.)
		 */
		led_11_red: led-0 {
			color = <LED_COLOR_ID_RED>;
			gpios = <&pioC 18 GPIO_ACTIVE_HIGH>;
		};

		/*
		 * (this led could use pwm, but we use it as simple gpio-led in u-boot only.)
		 */
		led_12_red: led-1 {
			color = <LED_COLOR_ID_RED>;
			gpios = <&pioC 19 GPIO_ACTIVE_HIGH>;
		};

		/*
		 * (this led could use pwm, but we use it as simple gpio-led in u-boot only.)
		 */
		led_13_red: led-2 {
			color = <LED_COLOR_ID_RED>;
			gpios = <&pioC 20 GPIO_ACTIVE_HIGH>;
		};

		/*
		 * (this led could use pwm, but we use it as simple gpio-led in u-boot only.)
		 */
		led_14_red: led-3 {
			color = <LED_COLOR_ID_RED>;
			gpios = <&pioC 21 GPIO_ACTIVE_HIGH>;
		};

		led_11_green: led-4 {
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&pioC 22 GPIO_ACTIVE_HIGH>;
		};

		led_12_green: led-5 {
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&pioC 23 GPIO_ACTIVE_HIGH>;
		};

		led_13_green: led-6 {
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&pioC 24 GPIO_ACTIVE_HIGH>;
		};

		led_14_green: led-7 {
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&pioC 25 GPIO_ACTIVE_HIGH>;
		};

		/*
		 * maybe not populated on PCB
		 */
		led_debug: led-8 {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_DEBUG;
			gpios = <&pioD 19 GPIO_ACTIVE_LOW>;
			default-state = "keep";
		};
	};

	soft_spi: soft-spi {
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_spi0>;
		status = "okay";

		compatible = "spi-gpio";
		#address-cells = <0x1>;
		#size-cells = <0x0>;

		sck-gpios = <&pioB 19 GPIO_ACTIVE_HIGH>;
		mosi-gpios = <&pioB 21 GPIO_ACTIVE_HIGH>;
		miso-gpios = <&pioB 22 GPIO_ACTIVE_HIGH>;
		cs-gpios = <&pioB 18 GPIO_ACTIVE_LOW>;
		num-chipselects = <1>;

		fpga: fpga@0 {
			pinctrl-names = "default";
			pinctrl-0 = <&pinctrl_fpga>;

			compatible = "efinix,fpga-passive-serial";
			spi-max-frequency = <50000000>;
			reg = <0>;
			nconfig-gpios = <&pioB 12 GPIO_ACTIVE_LOW>;
			nstat-gpios = <&pioB 14 GPIO_ACTIVE_LOW>;
			confd-gpios = <&pioB 13 GPIO_ACTIVE_HIGH>;
			altr,size = <EFINIX_TRION_T20Q144_SIZE>;
		};
	};
};

&dbgu {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_dbgu>;
	status = "okay"; /* Conflict with can0. */
};

&ebi {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ebi_addr_nand &pinctrl_ebi_data_0_7>;
	status = "okay";

	nand_controller: nand-controller {
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_nand_oe_we &pinctrl_nand_cs &pinctrl_nand_rb>;
		status = "okay";

		nand@3 {
			reg = <0x3 0x0 0x800000>;
			// workaround, use "soft wait" for now
			// rb-gpios = <&pioD 5 GPIO_ACTIVE_HIGH>;
			cs-gpios = <&pioD 4 GPIO_ACTIVE_HIGH>;
			nand-bus-width = <8>;
			nand-ecc-mode = "hw";
			nand-ecc-strength = <8>;
			nand-ecc-step-size = <512>;
			nand-on-flash-bbt;
			label = "atmel_nand";

			partitions {
				compatible = "fixed-partitions";
				#address-cells = <1>;
				#size-cells = <1>;

				/* 256 kiB */
				at91bootstrap@0 {
					label = "at91bootstrap";
					reg = <0x0 0x40000>;
				};

				/* 1 MiB */
				uboot@40000 {
					label = "u-boot";
					reg = <0x40000 0x100000>;
				};

				/* 256 kiB */
				ubootenv@140000 {
					label = "U-Boot Env";
					reg = <0x140000 0x40000>;
				};

				/* 256 kiB */
				ubootenvred@180000 {
					label = "U-Boot Env Redundant";
					reg = <0x180000 0x40000>;
				};

				/* reserved: 0x001c0000-0x00200000 (256 kiB) */

				/*
				 * 253 MiB.  Starts at offset 2 MiB after
				 * bootstrap, U-Boot and Env, and ends 1 MiB
				 * before end, leaving space for BBT.
				 */
				ubi@200000 {
					label = "UBI";
					reg = <0x200000 0xfd00000>;
				};

				/* reserved: 0x0ff00000-0x0ff80000 (512 kiB) */

				/* BBT: 0x0ff80000-0x10000000 (512 kiB) */
			};
		};
	};
};

&macb0 {
	phy-mode = "rmii";
	status = "okay";
};

&pinctrl {
	dbgu {
		pinctrl_dbgu: dbgu-0 {
			atmel,pins = <AT91_PIOA 9 AT91_PERIPH_A AT91_PINCTRL_PULL_UP
				      AT91_PIOA 10 AT91_PERIPH_A AT91_PINCTRL_NONE>;
		};
	};

	ebi {
		pinctrl_ebi_data_0_7: ebi-data-lsb-0 {
			atmel,pins =
				<AT91_PIOD 6 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 7 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 8 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 9 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 10 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 11 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 12 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 13 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)>;
		};

		pinctrl_ebi_addr_nand: ebi-addr-0 {
			atmel,pins =
				<AT91_PIOD 2 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 3 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)>;
		};
	};

	fpga {
		pinctrl_fpga: fpga-gpios {
			atmel,pins = <AT91_PIOB 12 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT		/* nCONFIG     */
				      AT91_PIOB 13 AT91_PERIPH_GPIO AT91_PINCTRL_NONE		/* CONF_DONE   */
				      AT91_PIOB 14 AT91_PERIPH_GPIO AT91_PINCTRL_NONE		/* nSTATUS     */
				      AT91_PIOB 15 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT>;	/* nFPGA_RESET */
		};
	};

	gpio-keys {
		pinctrl_key_gpio_default: pinctrl-key-gpio {
			atmel,pins = <AT91_PIOD 21 AT91_PERIPH_GPIO AT91_PINCTRL_NONE>;
		};
	};

	leds {
		pinctrl_gpio_leds: gpio-leds {
			atmel,pins = <AT91_PIOC 18 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 19 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 20 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 21 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 22 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 23 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 24 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOC 25 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT
				      AT91_PIOD 19 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT>;
		};
	};

	nand {
		pinctrl_nand_oe_we: nand-oe-we-0 {
			atmel,pins =
				<AT91_PIOD 0 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)
				 AT91_PIOD 1 AT91_PERIPH_A (AT91_PINCTRL_NONE | AT91_PINCTRL_SLEWRATE_DIS)>;
		};

		pinctrl_nand_rb: nand-rb-0 {
			atmel,pins =
				<AT91_PIOD 5 AT91_PERIPH_GPIO AT91_PINCTRL_PULL_UP>;
		};

		pinctrl_nand_cs: nand-cs-0 {
			atmel,pins =
				<AT91_PIOD 4 AT91_PERIPH_GPIO (AT91_PINCTRL_PULL_UP | AT91_PINCTRL_OUTPUT)>;
		};
	};

	spi {
		pinctrl_spi0: soft-spi {
			atmel,pins = <AT91_PIOB 18 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT	/* CSI_O */
				      AT91_PIOB 19 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT	/* DCLK  */
				      AT91_PIOB 20 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT	/* NCS   */
				      AT91_PIOB 21 AT91_PERIPH_GPIO AT91_PINCTRL_OUTPUT	/* MOSI  */
				      AT91_PIOB 22 AT91_PERIPH_GPIO AT91_PINCTRL_NONE>;	/* ASD0  */
		};
	};
};

&qspi {
	status = "disabled";
};

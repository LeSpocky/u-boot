/*
 * at91-vera2.dts - Device Tree file for Thorsis Technologies Vera2 board
 *
 * © 2021 Thorsis Technologies GmbH
 */
/dts-v1/;
#include "sama5d2.dtsi"
#include "sama5d2-pinfunc.h"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/pinctrl/at91.h>

/ {
	model = "Thorsis Technologies Vera2";
	compatible = "thorsis,vera2", "atmel,sama5d27", "atmel,sama5d2", "atmel,sama5";

	memory {
		reg = <0x20000000 0x04000000>;
	};

	chosen {
		u-boot,dm-pre-reloc;
		stdout-path = &uart1;
	};

	ahb {
		apb {
			macb0: ethernet@f8008000 {
				pinctrl-names = "default";
				pinctrl-0 = <&pinctrl_macb0_rmii>;
				phy-mode = "rmii";
				status = "okay";

				ethernet-phy@1 {
					reg = <0x1>;
				};
			};

			uart1: serial@f8020000 {
				pinctrl-names = "default";
				pinctrl-0 = <&pinctrl_uart1_default>;
				status = "okay";
				u-boot,dm-pre-reloc;
			};
		};
	};

	gpio-keys {
		compatible = "gpio-keys";
		status = "okay";

		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_key_gpio>;

		reset {
			label = "reset";
			gpios = <&pioA PIN_PD21 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};

	led-controller-0 {
		compatible = "gpio-leds";
		status = "okay";

		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_leds_gpio>;

		green-1 {
			label = "green:status";
			gpios = <&pioA PIN_PD7 GPIO_ACTIVE_LOW>;
			default-state = "on";
		};

		green-2 {
			label = "green:debug";
			gpios = <&pioA PIN_PD9 GPIO_ACTIVE_LOW>;
			default-state = "off";
		};
	};
};

&ebi {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_nand_default>;
	status = "okay";

	nand_controller: nand-controller {
		status = "okay";

		nand@3 {
			reg = <0x3 0x0 0x800000>;
			atmel,rb = <0>;

			nand-bus-width = <8>;
			nand-ecc-mode = "hw";
			nand-ecc-strength = <8>;
			nand-ecc-step-size = <512>;
			nand-on-flash-bbt;
			label = "atmel_nand";
		};
	};
};

&pioA {
	pinctrl_gpio_default: gpio_default {
		pinmux = <PIN_PB13__GPIO>;
		bias-pull-down;
	};

	pinctrl_key_gpio: key_gpio {
		pinmux = <PIN_PD21__GPIO>;
		bias-disable;
	};

	pinctrl_leds_gpio: leds_gpio {
		pinmux = <PIN_PD7__GPIO>,
			 <PIN_PD9__GPIO>;
		bias-disable;
	};

	pinctrl_macb0_rmii: macb0_rmii {
		pinmux = <PIN_PC10__GTXCK>,
			 <PIN_PC11__GTXEN>,
			 <PIN_PC12__GRXDV>,
			 <PIN_PC13__GRXER>,
			 <PIN_PC14__GRX0>,
			 <PIN_PC15__GRX1>,
			 <PIN_PC16__GTX0>,
			 <PIN_PC17__GTX1>,
			 <PIN_PC18__GMDC>,
			 <PIN_PC19__GMDIO>;
		bias-disable;
	};

	pinctrl_nand_default: nand_default {
		rd_we_data {
			pinmux = <PIN_PA22__D0>,
				 <PIN_PA23__D1>,
				 <PIN_PA24__D2>,
				 <PIN_PA25__D3>,
				 <PIN_PA26__D4>,
				 <PIN_PA27__D5>,
				 <PIN_PA28__D6>,
				 <PIN_PA29__D7>,
				 <PIN_PA30__NWE_NANDWE>,
				 <PIN_PB2__NRD_NANDOE>;
			bias-disable;
			atmel,drive-strength = <ATMEL_PIO_DRVSTR_ME>;
		};

		ale_cle_rdy_cs {
			pinmux = <PIN_PB0__A21_NANDALE>,
				 <PIN_PB1__A22_NANDCLE>,
				 <PIN_PC8__NANDRDY>,
				 <PIN_PA31__NCS3>;
			bias-pull-up;
		};
	};

	pinctrl_sdmmc0_default: sdmmc0_default {
		cmd_dat {
			pinmux = <PIN_PA1__SDMMC0_CMD>,
				 <PIN_PA2__SDMMC0_DAT0>,
				 <PIN_PA3__SDMMC0_DAT1>,
				 <PIN_PA4__SDMMC0_DAT2>,
				 <PIN_PA5__SDMMC0_DAT3>;
			bias-pull-up;
			u-boot,dm-pre-reloc;
		};

		ck_cd {
			pinmux = <PIN_PA0__SDMMC0_CK>,
				 <PIN_PA13__SDMMC0_CD>;
			bias-disable;
			u-boot,dm-pre-reloc;
		};
	};

	pinctrl_uart1_default: uart1_default {
		pinmux = <PIN_PD2__URXD1>,
			 <PIN_PD3__UTXD1>;
		bias-disable;
		u-boot,dm-pre-reloc;
	};

	/* init trigger pin to output-low with
	 * internal pull-down to avoid reboot loops
	 * triggered by monoflop at TPS54341
	 * EN input */
	pb13 {
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_gpio_default>;

		gpio-hog;
		gpios = <PIN_PB13 GPIO_ACTIVE_HIGH>;
		output-low;
	};
};

&sdmmc0 {
	bus-width = <4>;
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_sdmmc0_default>;
	status = "okay";
	no-1-8-v;
	u-boot,dm-pre-reloc;
};

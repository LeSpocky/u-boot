/*
 * at91-proficube.dts – Device Tree file for Thorsis Technologies ProfiCube board
 *
 * Copyright 2019 Thorsis Technologies GmbH
 */
/dts-v1/;
#include "sama5d2.dtsi"
#include "sama5d2-pinfunc.h"
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/pinctrl/at91.h>

/ {
	model = "Thorsis Technologies ProfiCube";
	compatible = "thorsis,proficube", "atmel,sama5d27", "atmel,sama5d2", "atmel,sama5";

	chosen {
		u-boot,dm-pre-reloc;
		stdout-path = &uart1;
	};

	/* fixup by dram_init() */
	memory {
		reg = <0x20000000 0x04000000>;
	};

	gpio_keys {
		compatible = "gpio-keys";
		status = "okay";

		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_key_gpio_default>;

		reset {
			label = "reset";
			gpios = <&pioA PIN_PD21 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
			debounce-interval = <60>;
		};
	};
};

&ebi {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_ebi_default>;
	status = "okay";

	nand_controller: nand-controller {
		pinctrl-names = "default";
		pinctrl-0 = <&pinctrl_nand_default>;
		status = "okay";

		nand@3 {
			reg = <0x3 0x0 0x800000>;
			atmel,rb = <0>;

			nand-bus-width = <8>;
			nand-ecc-mode = "hw";
			nand-on-flash-bbt;
			nand-ecc-strength = <8>;
			nand-ecc-step-size = <512>;
			label = "atmel_nand";
		};
	};
};

&macb0 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_macb0_default>;
	phy-mode = "rmii";
	status = "okay";

	/*
	 * We have to disable energy-detect because the 50 MHz
	 * ref_clk signal is used by the isnetbp FPGA, and must
	 * not be switched off. (#5804)
	 * Disabling this through DT was introduced in Linux
	 * v4.3 and fixed in v4.5.
	 */
	phy0: ethernet-phy@1 {
		reg = <1>;
		smsc,disable-energy-detect;
	};
};

&pioA {
	pinctrl_ebi_default: ebi_default {
		rd_we_data {
			pinmux = <PIN_PA22__D0>,
				 <PIN_PA23__D1>,
				 <PIN_PA24__D2>,
				 <PIN_PA25__D3>,
				 <PIN_PA26__D4>,
				 <PIN_PA27__D5>,
				 <PIN_PA28__D6>,
				 <PIN_PA29__D7>,
				 <PIN_PA30__NWE_NANDWE>,
				 <PIN_PB2__NRD_NANDOE>;
			bias-disable;
			atmel,drive-strength = <ATMEL_PIO_DRVSTR_ME>;
		};
	};

	pinctrl_key_gpio_default: key_gpio_default {
		pinmux = <PIN_PD21__GPIO>;
		bias-disable;
	};

	pinctrl_macb0_default: macb0_default {
		pinmux = <PIN_PC10__GTXCK>,
			 <PIN_PC11__GTXEN>,
			 <PIN_PC12__GRXDV>,
			 <PIN_PC13__GRXER>,
			 <PIN_PC14__GRX0>,
			 <PIN_PC15__GRX1>,
			 <PIN_PC16__GTX0>,
			 <PIN_PC17__GTX1>,
			 <PIN_PC18__GMDC>,
			 <PIN_PC19__GMDIO>;
		bias-disable;
	};

	pinctrl_nand_default: nand_default {
		ale_cle_rdy_cs {
			pinmux = <PIN_PB0__A21_NANDALE>,
				 <PIN_PB1__A22_NANDCLE>,
				 <PIN_PC8__NANDRDY>,
				 <PIN_PA31__NCS3>;
			bias-pull-up;
		};
	};

	pinctrl_spi0_default: spi0_default {
		pinmux = <PIN_PA14__SPI0_SPCK>, /* DCLK  */
			 <PIN_PA15__SPI0_MOSI>, /* DATA0 */
			 <PIN_PA16__SPI0_MISO>,
			 <PIN_PA17__GPIO>,      /* /CS0  */
			 <PIN_PA18__GPIO>;      /* /CS1  */
		bias-disable;
		u-boot,dm-pre-reloc;
	};

	pinctrl_uart1_default: uart1_default {
		pinmux = <PIN_PD2__URXD1>,
			 <PIN_PD3__UTXD1>;
		bias-disable;
		u-boot,dm-pre-reloc;
	};
};

&spi0 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_spi0_default>;
	status = "okay";

	cs-gpios = <&pioA 17 0>, <&pioA 18 0>, <0>, <0>;
	u-boot,dm-pre-reloc;
};

&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&pinctrl_uart1_default>;
	atmel,use-dma-rx;
	atmel,use-dma-tx;
	status = "okay";
};
